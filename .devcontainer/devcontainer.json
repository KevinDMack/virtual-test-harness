{
  "name": "Virtual Test Harness Development",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "1.10.5"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-azureterraform",
        "hashicorp.terraform"
      ]
    }
  },
  "postCreateCommand": "pip install --user pytest pytest-cov",
  "remoteUser": "vscode"
}
